# ── ADN deportivo objetivo del Rayo Vallecano 2026/27 ────────────────────────
# Perfil de estilo que la direccion deportiva busca en un entrenador.
# Estos valores son ASPIRACIONALES: no describen donde esta Rayo hoy,
# sino el estilo ideal que queremos en el banquillo.
#
# Ejes en escala 0-100 (percentil relativo a la liga):
#   100 = top absoluto   |   50 = media   |   0 = peor
# El "peso" indica cuanto pondera cada eje en el score de encaje.
# Pesos deben sumar 1.0 exactamente.
#
# Identidad Rayo: presion + transiciones + verticalidad > posesion + tecnicismo

target_style:
  presion_alta:          {ideal: 78, weight: 0.22}   # presion intensa, PPDA bajo — seña de identidad
  uso_transiciones:      {ideal: 82, weight: 0.22}   # ataque en transicion — identidad Vallecas
  verticalidad:          {ideal: 78, weight: 0.18}   # juego directo, pase largo, velocidad
  solidez_defensiva:     {ideal: 68, weight: 0.16}   # orden defensivo — prioridad, aunque no elite
  intensidad_defensiva:  {ideal: 72, weight: 0.12}   # trabajo sin balon, entradas, duelos
  tendencia_ofensiva:    {ideal: 65, weight: 0.07}   # queremos mejorar el gol — aspiration
  posesion:              {ideal: 45, weight: 0.03}   # no somos equipo de posesion

context_weights:
  laliga_experience:     0.20   # experiencia en LaLiga (clave para adaptacion rapida)
  budget_fit:            0.15   # encaje con masa salarial reducida del club
  squad_compatibility:   0.15   # compatibilidad con la p