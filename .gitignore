# =============================================================================
#  .gitignore — Rayo Vallecano Scouting Tool (TFM)
# =============================================================================

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg
*.egg-info/
.eggs/
build/
dist/
develop-eggs/
sdist/
*.so

# ── Entornos virtuales ────────────────────────────────────────────────────────
.env
.venv/
env/
venv/
ENV/

# ── Variables de entorno / secretos ────────────────────────────────────────────
*.env
secrets.yaml
secrets.json

# ── Caché de la app (background callbacks Dash / diskcache) ─────────────────────
.cache/
rayo_dash_cache/

# ── Marcador de instalación creado por INICIAR_HERRAMIENTA.bat ──────────────────
.deps_ok

# ── Reportes PDF generados por la herramienta (se regeneran en la app) ──────────
data/reports_out/
*.pdf

# =============================================================================
#  DATOS
# =============================================================================
# Los .parquet de runtime SÍ se versionan (necesarios para que la app arranque
# tras un git clone). Sólo se ignoran los volcados crudos de API, que son
# grandes y se regeneran con los scripts de scripts/.
# Volcado crudo Transfermarkt (~33 MB)
data/processed/tm_api_raw.json
# Volcado crudo económico TM
data/processed/tm_economic_raw.json
# Logs intermedios del proceso de enriquecido
data/processed/tm_enrichment_*.csv

# Carpetas de entrada (vacías salvo .gitkeep; los ZIPs OPTA son externos)
data/raw/*
data/interim/*
data/opta_json/*
data/external/cache/*
!**/.gitkeep

# ── Backups y temporales de oficina ─────────────────────────────────────────────
*.bak
~$*
*.tmp

# ── Notebooks exploratorios y checkpoints ───────────────────────────────────────
*.ipynb
.ipynb_checkpoints/

# ── Tests / cachés de pytest ────────────────────────────────────────────────────
.pytest_cache/
pytest-cache-files*/

# ── IDEs y SO ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ────────────────────────────────────────────────────────────────────────
*.log
logs/
